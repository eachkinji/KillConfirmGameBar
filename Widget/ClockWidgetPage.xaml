<Page
    x:Class="TestXboxGameBar.ClockWidgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TestXboxGameBar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#24303D" />
            <Setter Property="Foreground" Value="#FFF8FAFC" />
            <Setter Property="BorderBrush" Value="#3E5164" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>

        <Style x:Key="CompactIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#24303D" />
            <Setter Property="Foreground" Value="#FFF8FAFC" />
            <Setter Property="BorderBrush" Value="#3E5164" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="OverlayComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="#FFF8FAFC" />
            <Setter Property="Background" Value="#1E2833" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource OverlayComboBoxStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,0" />
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid
            x:Name="AnimationLayer"
            HorizontalAlignment="Stretch"
            IsHitTestVisible="False"
            VerticalAlignment="Stretch"
            RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="AnimationTransform" />
            </Grid.RenderTransform>

            <controls:KillConfirmAnimation
                x:Name="PrimaryKillAnimation"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

            <controls:KillConfirmAnimation
                x:Name="BadgeKillAnimation"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

            <Border
                x:Name="StreakBadge"
                Margin="0,12,12,0"
                Padding="10,4"
                HorizontalAlignment="Right"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                Background="#E8F59E0B"
                BorderBrush="#55FFF7ED"
                BorderThickness="1"
                CornerRadius="14"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="StreakBadgeText"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="#FF111827"
                    Text="x7" />
            </Border>
        </Grid>

        <Border
            x:Name="ControlPanel"
            Margin="6"
            Padding="6"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Width="400"
            MaxWidth="400"
            Background="#E711161D"
            BorderBrush="#3D4D61"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowSpacing="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="96" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="StatusHintBox"
                        Height="28"
                        VerticalAlignment="Center"
                        Padding="8,0"
                        Background="#1E2833"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        CornerRadius="9"
                        ToolTipService.ToolTip="Click the pin button in Xbox Game Bar's top-right corner.">
                        <TextBlock
                            x:Name="PinHintText"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#FFFFE7A3"
                            Text="Pin the widget in the top-right to keep the icon on screen."
                            TextTrimming="CharacterEllipsis" />
                    </Border>

                    <ComboBox
                        x:Name="LanguageSelector"
                        Grid.Column="1"
                        Style="{StaticResource OverlayComboBoxStyle}"
                        SelectedIndex="0"
                        SelectionChanged="OnLanguageSelectionChanged"
                        ToolTipService.ToolTip="Language">
                        <ComboBoxItem Tag="en-US">EN</ComboBoxItem>
                        <ComboBoxItem Tag="zh-CN">中文</ComboBoxItem>
                    </ComboBox>

                    <Border
                        Grid.Column="2"
                        Width="96"
                        Padding="8,0"
                        Height="28"
                        VerticalAlignment="Center"
                        Background="#1E2833"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        CornerRadius="9">
                        <TextBlock
                            x:Name="VersionText"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#FFBFD0E3"
                            Text="v..." />
                    </Border>
                </Grid>

                <Grid
                    Grid.Row="1"
                    ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="StartServiceButton"
                        Grid.Column="0"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnStartServiceClick"
                        ToolTipService.ToolTip="Start service">
                        <PathIcon Data="M7,1 L9,1 L9,8 L7,8 Z M4.2,3.4 A5,5 0 1 0 11.8,3.4 L10.4,4.8 A3,3 0 1 1 5.6,4.8 Z" />
                    </Button>

                    <Button
                        x:Name="CheckServiceButton"
                        Grid.Column="1"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnCheckServerClick"
                        ToolTipService.ToolTip="Check service">
                        <PathIcon Data="M2,8 L6,12 L14,3 M13,10 L13,14 L9,14" />
                    </Button>

                    <Button
                        x:Name="OpenGuideButton"
                        Grid.Column="2"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnOpenGuideClick"
                        ToolTipService.ToolTip="Open guide">
                        <PathIcon Data="M3,2 L12,2 L12,14 L3,14 Z M5,5 L10,5 M5,8 L10,8 M5,11 L8,11" />
                    </Button>

                    <Border
                        x:Name="ConnectionStatusBadge"
                        Grid.Column="3"
                        Width="54"
                        Height="28"
                        Background="#223040"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        CornerRadius="9"
                        ToolTipService.ToolTip="Service status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Border
                                x:Name="ConnectionDot"
                                Width="8"
                                Height="8"
                                Background="#FF6B7280"
                                CornerRadius="4" />
                            <TextBlock
                                x:Name="ServiceBadgeText"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#FFBFD0E3"
                                Text="SVC" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="CfgStatusBadge"
                        Grid.Column="4"
                        Width="54"
                        Height="28"
                        Background="#223040"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        CornerRadius="9"
                        ToolTipService.ToolTip="CFG status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Border
                                x:Name="CfgDot"
                                Width="8"
                                Height="8"
                                Background="#FF6B7280"
                                CornerRadius="4" />
                            <TextBlock
                                x:Name="CfgBadgeText"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#FFBFD0E3"
                                Text="CFG" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="GsiStatusBadge"
                        Grid.Column="5"
                        Width="46"
                        Height="28"
                        Background="#223040"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        CornerRadius="9"
                        ToolTipService.ToolTip="CS2 data status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Border
                                x:Name="GsiDot"
                                Width="8"
                                Height="8"
                                Background="#FF6B7280"
                                CornerRadius="4" />
                            <TextBlock
                                x:Name="GsiBadgeText"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#FFBFD0E3"
                                Text="GSI" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="AnimationCacheStatusBadge"
                        Grid.Column="6"
                        Width="46"
                        Height="28"
                        Background="#223040"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        CornerRadius="9"
                        ToolTipService.ToolTip="Animation cache status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Border
                                x:Name="AnimationCacheDot"
                                Width="8"
                                Height="8"
                                Background="#FF6B7280"
                                CornerRadius="4" />
                            <TextBlock
                                x:Name="AnimationCacheBadgeText"
                                FontSize="9"
                                FontWeight="SemiBold"
                                Foreground="#FFBFD0E3"
                                Text="ANI" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid
                    Grid.Row="2"
                    ColumnSpacing="6"
                    Visibility="Collapsed"
                    x:Name="ServiceDiagnosticRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="ServiceDiagnosticText"
                        VerticalAlignment="Center"
                        FontSize="9"
                        FontWeight="SemiBold"
                        Foreground="#FFFFD166"
                        Text="Service failed to start. Restart your PC and try again."
                        TextTrimming="CharacterEllipsis" />

                    <Button
                        x:Name="FreePortButton"
                        Grid.Column="1"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnFreePortClick"
                        ToolTipService.ToolTip="Free service port">
                        <PathIcon Data="M3,8 L7,4 L7,7 L12,7 L12,9 L7,9 L7,12 Z M10,4 L14,4 L14,12 L10,12 L10,10 L12,10 L12,6 L10,6 Z" />
                    </Button>

                    <Button
                        x:Name="OpenLogsButton"
                        Grid.Column="2"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnOpenLogsClick"
                        ToolTipService.ToolTip="Open logs folder">
                        <PathIcon Data="M2,4 L6,4 L7.2,6 L14,6 L14,13 L2,13 Z M4,8 L12,8" />
                    </Button>
                </Grid>

                <Grid
                    Grid.Row="3"
                    ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*" />
                        <ColumnDefinition Width="0.7*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        x:Name="VoicePackSelector"
                        Grid.Column="0"
                        Style="{StaticResource OverlayComboBoxStyle}"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0"
                        SelectionChanged="OnVoicePackSelectionChanged"
                        ToolTipService.ToolTip="Select voice pack">
                        <ComboBoxItem x:Name="CrossfireSwatGrVoiceItem" Tag="crossfire_swat_gr">swat GR</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireSwatBlVoiceItem" Tag="crossfire_swat_bl">swat BL</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireFlyingTigerGrVoiceItem" Tag="crossfire_flying_tiger_gr">tiger GR</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireFlyingTigerBlVoiceItem" Tag="crossfire_flying_tiger_bl">tiger BL</ComboBoxItem>
                        <ComboBoxItem Tag="crossfire_v_sex">cfsex</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireWomenGrVoiceItem" Tag="crossfire_women_gr">women GR</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireWomenBlVoiceItem" Tag="crossfire_women_bl">women BL</ComboBoxItem>
                    </ComboBox>

                    <ComboBox
                        x:Name="TestPresetSelector"
                        Grid.Column="1"
                        Style="{StaticResource OverlayComboBoxStyle}"
                        MinWidth="60"
                        SelectedIndex="0"
                        ToolTipService.ToolTip="Select preview or test preset">
                        <ComboBoxItem Tag="one">1</ComboBoxItem>
                        <ComboBoxItem Tag="one_hs">1 HS</ComboBoxItem>
                        <ComboBoxItem Tag="one_knife">1 K</ComboBoxItem>
                        <ComboBoxItem Tag="one_first">1 F</ComboBoxItem>
                        <ComboBoxItem Tag="one_last">1 L</ComboBoxItem>
                        <ComboBoxItem Tag="gold_first">GF</ComboBoxItem>
                        <ComboBoxItem Tag="gold_last">GL</ComboBoxItem>
                        <ComboBoxItem Tag="two">2</ComboBoxItem>
                        <ComboBoxItem Tag="three">3</ComboBoxItem>
                        <ComboBoxItem Tag="four">4</ComboBoxItem>
                        <ComboBoxItem Tag="five">5</ComboBoxItem>
                        <ComboBoxItem Tag="six">6</ComboBoxItem>
                        <ComboBoxItem Tag="seven">7</ComboBoxItem>
                        <ComboBoxItem Tag="eight">8</ComboBoxItem>
                        <ComboBoxItem Tag="nine">9</ComboBoxItem>
                        <ComboBoxItem Tag="badge_first">FK</ComboBoxItem>
                        <ComboBoxItem Tag="badge_last">LK</ComboBoxItem>
                    </ComboBox>

                    <Button
                        x:Name="PreviewButton"
                        Grid.Column="2"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnPreviewClick"
                        ToolTipService.ToolTip="Preview selected result">
                        <PathIcon Data="M4,2 L13,8 L4,14 Z" />
                    </Button>

                    <Button
                        x:Name="SendTestButton"
                        Grid.Column="3"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnTestEventClick"
                        ToolTipService.ToolTip="Send selected test event">
                        <PathIcon Data="M2,6 L5,6 L9,2 L9,14 L5,10 L2,10 Z M11,5 L13,7 L13,9 L11,11 Z" />
                    </Button>
                </Grid>

                <Grid
                    x:Name="CfgActionRow"
                    Grid.Row="4"
                    ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="50"
                        Height="28"
                        Background="#1E2833"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        CornerRadius="9">
                        <TextBlock
                            x:Name="CfgLabelText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#FFBFD0E3"
                            Text="CFG" />
                    </Border>

                    <Button
                        x:Name="SelectCsFolderButton"
                        Grid.Column="1"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnSelectCsFolderClick"
                        ToolTipService.ToolTip="Select CS2 root folder">
                        <PathIcon Data="M2,4 L6,4 L7.2,6 L14,6 L14,13 L2,13 Z" />
                    </Button>

                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Spacing="1">
                        <TextBlock
                            x:Name="CfgStatusText"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#FFBFD0E3"
                            Text="CFG not checked"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            x:Name="CfgHintText"
                            FontSize="9"
                            Foreground="#FF93A4B8"
                            Text="Pick CS2 root folder"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Button
                        x:Name="CfgInstallButton"
                        Grid.Column="3"
                        MinWidth="42"
                        Height="28"
                        Padding="8,0"
                        Background="#24303D"
                        BorderBrush="#3E5164"
                        BorderThickness="1"
                        Click="OnInstallCfgClick"
                        Content="Add"
                        CornerRadius="9"
                        Foreground="#FFF8FAFC"
                        ToolTipService.ToolTip="Add missing CFG"
                        Visibility="Collapsed" />
                </Grid>

                <Grid
                    Grid.Row="5"
                    ColumnSpacing="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="DefaultSizeButton"
                        Grid.Column="0"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnResizeClick"
                        ToolTipService.ToolTip="Default size">
                        <PathIcon Data="M3,3 L13,3 L13,13 L3,13 Z M5,5 L11,5 L11,11 L5,11 Z" />
                    </Button>

                    <Button
                        x:Name="CenterButton"
                        Grid.Column="1"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnCenterClick"
                        ToolTipService.ToolTip="Center window">
                        <PathIcon Data="M8,1 L8,15 M1,8 L15,8 M4,4 L12,4 L12,12 L4,12 Z" />
                    </Button>

                    <Button
                        x:Name="LowerThirdButton"
                        Grid.Column="2"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnLowerThirdClick"
                        ToolTipService.ToolTip="Place icon at bottom">
                        <PathIcon Data="M8,2 L13,7 L10,7 L10,10 L6,10 L6,7 L3,7 Z M2,12 L14,12 L14,14 L2,14 Z" />
                    </Button>

                    <Button
                        x:Name="MoveUpButton"
                        Grid.Column="3"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnMoveUpClick"
                        ToolTipService.ToolTip="Move icon up">
                        <PathIcon Data="M8,2 L14,10 L10,10 L10,15 L6,15 L6,10 L2,10 Z" />
                    </Button>

                    <Button
                        x:Name="MoveDownButton"
                        Grid.Column="4"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnMoveDownClick"
                        ToolTipService.ToolTip="Move icon down">
                        <PathIcon Data="M6,1 L10,1 L10,6 L14,6 L8,14 L2,6 L6,6 Z" />
                    </Button>

                    <Button
                        x:Name="ScaleDownButton"
                        Grid.Column="5"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnScaleDownClick"
                        ToolTipService.ToolTip="Shrink icon">
                        <PathIcon Data="M3,7 L13,7 L13,9 L3,9 Z" />
                    </Button>

                    <Button
                        x:Name="ScaleUpButton"
                        Grid.Column="6"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnScaleUpClick"
                        ToolTipService.ToolTip="Enlarge icon">
                        <PathIcon Data="M7,3 L9,3 L9,7 L13,7 L13,9 L9,9 L9,13 L7,13 L7,9 L3,9 L3,7 L7,7 Z" />
                    </Button>

                    <PathIcon
                        x:Name="BrightnessIcon"
                        Grid.Column="7"
                        Width="16"
                        Height="16"
                        Foreground="#FFFFE7A3"
                        Data="M8,1 L10,5 L14,6 L11,9 L12,14 L8,12 L4,14 L5,9 L2,6 L6,5 Z"
                        ToolTipService.ToolTip="Animation brightness" />

                    <ComboBox
                        x:Name="BrightnessSelector"
                        Grid.Column="8"
                        Width="46"
                        Style="{StaticResource CompactComboBoxStyle}"
                        SelectionChanged="OnBrightnessSelectionChanged"
                        ToolTipService.ToolTip="Animation brightness">
                        <ComboBoxItem Tag="40">40%</ComboBoxItem>
                        <ComboBoxItem Tag="50">50%</ComboBoxItem>
                        <ComboBoxItem Tag="60">60%</ComboBoxItem>
                        <ComboBoxItem Tag="70">70%</ComboBoxItem>
                        <ComboBoxItem Tag="80">80%</ComboBoxItem>
                        <ComboBoxItem Tag="90">90%</ComboBoxItem>
                        <ComboBoxItem Tag="100">100%</ComboBoxItem>
                    </ComboBox>

                    <PathIcon
                        x:Name="ContrastIcon"
                        Grid.Column="9"
                        Width="16"
                        Height="16"
                        Foreground="#FFE5E7EB"
                        Data="M2,2 L14,2 L14,14 L2,14 Z M8,2 L14,2 L14,14 L8,14 Z"
                        ToolTipService.ToolTip="Animation contrast" />

                    <ComboBox
                        x:Name="ContrastSelector"
                        Grid.Column="10"
                        Width="46"
                        Style="{StaticResource CompactComboBoxStyle}"
                        SelectionChanged="OnContrastSelectionChanged"
                        ToolTipService.ToolTip="Animation contrast">
                        <ComboBoxItem Tag="40">40%</ComboBoxItem>
                        <ComboBoxItem Tag="50">50%</ComboBoxItem>
                        <ComboBoxItem Tag="60">60%</ComboBoxItem>
                        <ComboBoxItem Tag="70">70%</ComboBoxItem>
                        <ComboBoxItem Tag="80">80%</ComboBoxItem>
                        <ComboBoxItem Tag="90">90%</ComboBoxItem>
                        <ComboBoxItem Tag="100">100%</ComboBoxItem>
                    </ComboBox>

                    <Button
                        x:Name="ResetVisualButton"
                        Grid.Column="11"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="OnResetVisualAdjustmentsClick"
                        ToolTipService.ToolTip="Reset visual adjustments">
                        <PathIcon Data="M8,1 L14,4 L8,7 L8,4 A4,4 0 1 0 12,8 L14,8 A6,6 0 1 1 8,2 Z" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
