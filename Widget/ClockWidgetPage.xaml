<Page
    x:Class="TestXboxGameBar.ClockWidgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TestXboxGameBar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="IconHostStyle" TargetType="Grid">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CompactIconHostStyle" TargetType="Grid">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FluentPathIconStyle" TargetType="PathIcon">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#FFF8FAFC" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.58" ScaleY="0.58" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentTinyPathIconStyle" TargetType="PathIcon" BasedOn="{StaticResource FluentPathIconStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.52" ScaleY="0.52" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#343941" />
            <Setter Property="Foreground" Value="#FFF8FAFC" />
            <Setter Property="BorderBrush" Value="#4C5560" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#3D444D" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#2A2F36" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#343941" />
            <Setter Property="Foreground" Value="#FFF8FAFC" />
            <Setter Property="BorderBrush" Value="#4C5560" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#3D444D" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#2A2F36" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,0,6,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#FFF8FAFC" />
            <Setter Property="Background" Value="#343941" />
            <Setter Property="BorderBrush" Value="#77818E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource OverlayComboBoxStyle}">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Padding" Value="9,0,5,0" />
            <Setter Property="CornerRadius" Value="11" />
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid
            x:Name="AnimationLayer"
            HorizontalAlignment="Stretch"
            IsHitTestVisible="False"
            VerticalAlignment="Stretch"
            RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="AnimationTransform" />
            </Grid.RenderTransform>

            <controls:KillConfirmAnimation
                x:Name="PrimaryKillAnimation"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

            <controls:KillConfirmAnimation
                x:Name="BadgeKillAnimation"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

            <Border
                x:Name="StreakBadge"
                Margin="0,12,12,0"
                Padding="10,4"
                HorizontalAlignment="Right"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                Background="#E8F59E0B"
                BorderBrush="#55FFF7ED"
                BorderThickness="1"
                CornerRadius="14"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="StreakBadgeText"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#FF111827"
                    Text="x7" />
            </Border>
        </Grid>

        <Border
            x:Name="ControlPanel"
            Margin="6"
            Padding="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Width="312"
            MaxWidth="312"
            Background="#F022252A"
            BorderBrush="#2F3338"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="StatusHintBox"
                        Height="24"
                        VerticalAlignment="Center"
                        Padding="7,0"
                        Background="#303640"
                        BorderBrush="#4D5660"
                        BorderThickness="1"
                        CornerRadius="11"
                        ToolTipService.ToolTip="Click the pin button in Xbox Game Bar's top-right corner.">
                        <TextBlock
                            x:Name="PinHintText"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#FFFFD54A"
                            Text="Pin the widget in the top-right to keep the icon on screen."
                            TextTrimming="CharacterEllipsis" />
                    </Border>

                    <ComboBox
                        x:Name="LanguageSelector"
                        Grid.Column="1"
                        Width="78"
                        Style="{StaticResource OverlayComboBoxStyle}"
                        SelectedIndex="0"
                        SelectionChanged="OnLanguageSelectionChanged"
                        ToolTipService.ToolTip="Language">
                        <ComboBoxItem Tag="en-US">EN</ComboBoxItem>
                        <ComboBoxItem Tag="zh-CN">中文</ComboBoxItem>
                    </ComboBox>

                    <Border
                        Grid.Column="2"
                        Width="36"
                        Padding="4,0"
                        Height="24"
                        VerticalAlignment="Center"
                        Background="#303640"
                        BorderBrush="#4D5660"
                        BorderThickness="1"
                        CornerRadius="11">
                        <TextBlock
                            x:Name="VersionText"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#FFE8EAED"
                            Text="v..." />
                    </Border>
                </Grid>

                <Grid
                    Grid.Row="1"
                    ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="StartServiceButton"
                        Grid.Column="0"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnStartServiceClick"
                        ToolTipService.ToolTip="Start service">
                        <Grid Style="{StaticResource IconHostStyle}">
                            <PathIcon Style="{StaticResource FluentPathIconStyle}" Data="M8.2042 4.82046C8.57962 4.64545 9.02584 4.80792 9.20085 5.18334C9.37586 5.55876 9.2134 6.00498 8.83797 6.18C6.21382 7.4033 4.5 10.0416 4.5 12.9914C4.5 17.1386 7.85759 20.5002 11.9989 20.5002C16.1403 20.5002 19.4979 17.1386 19.4979 12.9914C19.4979 10.0477 17.7912 7.41389 15.1753 6.18718C14.8002 6.01131 14.6388 5.56472 14.8147 5.1897C14.9905 4.81467 15.4371 4.65322 15.8121 4.82909C18.9502 6.30065 20.9979 9.46066 20.9979 12.9914C20.9979 17.9666 16.9691 22.0002 11.9989 22.0002C7.02876 22.0002 3 17.9666 3 12.9914C3 9.45334 5.05623 6.28796 8.2042 4.82046ZM11.9989 2.49609C12.3786 2.49609 12.6924 2.77825 12.7421 3.14432L12.7489 3.24609V10.746C12.7489 11.1602 12.4132 11.496 11.9989 11.496C11.6192 11.496 11.3055 11.2139 11.2558 10.8478L11.2489 10.746V3.24609C11.2489 2.83188 11.5847 2.49609 11.9989 2.49609Z" />
                        </Grid>
                    </Button>

                    <Button
                        x:Name="CheckServiceButton"
                        Grid.Column="1"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnCheckServerClick"
                        ToolTipService.ToolTip="Check service">
                        <Grid Style="{StaticResource IconHostStyle}">
                            <PathIcon Style="{StaticResource FluentPathIconStyle}" Data="M4.53033 12.9697C4.23744 12.6768 3.76256 12.6768 3.46967 12.9697C3.17678 13.2626 3.17678 13.7374 3.46967 14.0303L7.96967 18.5303C8.26256 18.8232 8.73744 18.8232 9.03033 18.5303L20.0303 7.53033C20.3232 7.23744 20.3232 6.76256 20.0303 6.46967C19.7374 6.17678 19.2626 6.17678 18.9697 6.46967L8.5 16.9393L4.53033 12.9697Z" />
                        </Grid>
                    </Button>

                    <Button
                        x:Name="OpenGuideButton"
                        Grid.Column="2"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnOpenGuideClick"
                        ToolTipService.ToolTip="Open guide">
                        <Grid Style="{StaticResource IconHostStyle}">
                            <PathIcon Style="{StaticResource FluentPathIconStyle}" Data="M13.25 7C13.25 7.55228 12.8023 8 12.25 8C11.6977 8 11.25 7.55228 11.25 7C11.25 6.44772 11.6977 6 12.25 6C12.8023 6 13.25 6.44772 13.25 7ZM11.5 9.75L11.5 14.75C11.5 15.1642 11.8358 15.5 12.25 15.5C12.6642 15.5 13 15.1642 13 14.75V9.75C13 9.33579 12.6642 9 12.25 9C11.8358 9 11.5 9.33579 11.5 9.75ZM4 4.5C4 3.11929 5.11929 2 6.5 2H18C19.3807 2 20.5 3.11929 20.5 4.5V18.75C20.5 19.1642 20.1642 19.5 19.75 19.5H5.5C5.5 20.0523 5.94772 20.5 6.5 20.5H19.75C20.1642 20.5 20.5 20.8358 20.5 21.25C20.5 21.6642 20.1642 22 19.75 22H6.5C5.11929 22 4 20.8807 4 19.5V4.5ZM19 18V4.5C19 3.94772 18.5523 3.5 18 3.5H6.5C5.94772 3.5 5.5 3.94772 5.5 4.5V18H19Z" />
                        </Grid>
                    </Button>

                    <Border
                        x:Name="ConnectionStatusBadge"
                        Grid.Column="3"
                        Width="52"
                        Height="24"
                        Background="#303640"
                        BorderBrush="#4D5660"
                        BorderThickness="1"
                        CornerRadius="11"
                        ToolTipService.ToolTip="Service status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Border
                                x:Name="ConnectionDot"
                                Width="7"
                                Height="7"
                                Background="#FF6B7280"
                                CornerRadius="3.5" />
                            <TextBlock
                                x:Name="ServiceBadgeText"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#FFE8EAED"
                                Text="SVC" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="CfgStatusBadge"
                        Grid.Column="4"
                        Width="52"
                        Height="24"
                        Background="#303640"
                        BorderBrush="#4D5660"
                        BorderThickness="1"
                        CornerRadius="11"
                        ToolTipService.ToolTip="CFG status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Border
                                x:Name="CfgDot"
                                Width="7"
                                Height="7"
                                Background="#FF6B7280"
                                CornerRadius="3.5" />
                            <TextBlock
                                x:Name="CfgBadgeText"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#FFE8EAED"
                                Text="CFG" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="GsiStatusBadge"
                        Grid.Column="5"
                        Width="44"
                        Height="24"
                        Background="#303640"
                        BorderBrush="#4D5660"
                        BorderThickness="1"
                        CornerRadius="11"
                        ToolTipService.ToolTip="CS2 data status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Border
                                x:Name="GsiDot"
                                Width="7"
                                Height="7"
                                Background="#FF6B7280"
                                CornerRadius="3.5" />
                            <TextBlock
                                x:Name="GsiBadgeText"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#FFE8EAED"
                                Text="GSI" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="AnimationCacheStatusBadge"
                        Grid.Column="6"
                        Width="44"
                        Height="24"
                        Background="#303640"
                        BorderBrush="#4D5660"
                        BorderThickness="1"
                        CornerRadius="11"
                        ToolTipService.ToolTip="Animation cache status">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Border
                                x:Name="AnimationCacheDot"
                                Width="7"
                                Height="7"
                                Background="#FF6B7280"
                                CornerRadius="3.5" />
                            <TextBlock
                                x:Name="AnimationCacheBadgeText"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#FFE8EAED"
                                Text="ANI" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid
                    Grid.Row="2"
                    ColumnSpacing="6"
                    Visibility="Collapsed"
                    x:Name="ServiceDiagnosticRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="ServiceDiagnosticText"
                        VerticalAlignment="Center"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#FFFFD166"
                        Text="Service failed to start. Restart your PC and try again."
                        TextTrimming="CharacterEllipsis" />

                    <Button
                        x:Name="FreePortButton"
                        Grid.Column="1"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnFreePortClick"
                        ToolTipService.ToolTip="Free service port">
                        <Grid Style="{StaticResource IconHostStyle}">
                            <PathIcon Style="{StaticResource FluentPathIconStyle}" Data="M6.25 3C4.45507 3 3 4.45507 3 6.25V17.75C3 19.5449 4.45507 21 6.25 21H15.25C15.6642 21 16 20.6642 16 20.25C16 19.8358 15.6642 19.5 15.25 19.5H6.25C5.2835 19.5 4.5 18.7165 4.5 17.75V6.25C4.5 5.2835 5.2835 4.5 6.25 4.5H15.25C15.6642 4.5 16 4.16421 16 3.75C16 3.33579 15.6642 3 15.25 3H6.25ZM17.5303 7.21967C17.2374 6.92678 16.7626 6.92678 16.4697 7.21967C16.1768 7.51256 16.1768 7.98744 16.4697 8.28033L19.4393 11.25H8.75C8.33579 11.25 8 11.5858 8 12C8 12.4142 8.33579 12.75 8.75 12.75H19.4393L16.4697 15.7197C16.1768 16.0126 16.1768 16.4874 16.4697 16.7803C16.7626 17.0732 17.2374 17.0732 17.5303 16.7803L21.7803 12.5303C22.0732 12.2374 22.0732 11.7626 21.7803 11.4697L17.5303 7.21967Z" />
                        </Grid>
                    </Button>

                    <Button
                        x:Name="OpenLogsButton"
                        Grid.Column="2"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnOpenLogsClick"
                        ToolTipService.ToolTip="Open logs folder">
                        <Grid Style="{StaticResource IconHostStyle}">
                            <PathIcon Style="{StaticResource FluentPathIconStyle}" Data="M3.50014 6.25C3.50014 5.2835 4.28364 4.5 5.25014 4.5H8.12882C8.32773 4.5 8.5185 4.57902 8.65915 4.71967L10.7198 6.78033C10.8605 6.92098 11.0512 7 11.2501 7H16.7501C17.7166 7 18.5001 7.7835 18.5001 8.75C18.5001 8.83602 18.5146 8.91866 18.5413 8.99561L8.71867 8.99561C7.37893 8.99561 6.14095 9.71035 5.47108 10.8706L3.50014 14.2844V6.25ZM2.00036 17.7883C2.02089 19.5656 3.468 21 5.25014 21H11.0001C11.0292 21 11.058 20.9983 11.0862 20.9951H16.2812C17.6209 20.9951 18.8589 20.2804 19.5288 19.1201L22.5596 13.8706C23.7748 11.7657 22.3337 9.14964 19.9567 9.00214C19.9848 8.92334 20.0001 8.83846 20.0001 8.75C20.0001 6.95507 18.5451 5.5 16.7501 5.5H11.5608L9.71981 3.65901C9.29786 3.23705 8.72556 3 8.12882 3H5.25014C3.45522 3 2.00014 4.45507 2.00014 6.25V17.71C1.9999 17.7362 1.99997 17.7623 2.00036 17.7883ZM8.71867 10.4956L19.745 10.4956C21.0921 10.4956 21.9341 11.9539 21.2605 13.1206L18.2297 18.3701C17.8278 19.0663 17.085 19.4951 16.2812 19.4951H5.25485C3.9077 19.4951 3.06573 18.0368 3.7393 16.8701L6.77011 11.6206C7.17204 10.9245 7.91482 10.4956 8.71867 10.4956Z" />
                        </Grid>
                    </Button>
                </Grid>

                <Grid
                    Grid.Row="3"
                    ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="116" />
                        <ColumnDefinition Width="54" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        x:Name="VoicePackSelector"
                        Grid.Column="0"
                        Width="116"
                        Style="{StaticResource OverlayComboBoxStyle}"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0"
                        SelectionChanged="OnVoicePackSelectionChanged"
                        ToolTipService.ToolTip="Select voice pack">
                        <ComboBoxItem x:Name="CrossfireSwatGrVoiceItem" Tag="crossfire_swat_gr">swat GR</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireSwatBlVoiceItem" Tag="crossfire_swat_bl">swat BL</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireFlyingTigerGrVoiceItem" Tag="crossfire_flying_tiger_gr">tiger GR</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireFlyingTigerBlVoiceItem" Tag="crossfire_flying_tiger_bl">tiger BL</ComboBoxItem>
                        <ComboBoxItem Tag="crossfire_v_sex">cfsex</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireWomenGrVoiceItem" Tag="crossfire_women_gr">women GR</ComboBoxItem>
                        <ComboBoxItem x:Name="CrossfireWomenBlVoiceItem" Tag="crossfire_women_bl">women BL</ComboBoxItem>
                    </ComboBox>

                    <ComboBox
                        x:Name="TestPresetSelector"
                        Grid.Column="1"
                        Width="54"
                        Style="{StaticResource OverlayComboBoxStyle}"
                        MinWidth="54"
                        SelectedIndex="0"
                        ToolTipService.ToolTip="Select test preset">
                        <ComboBoxItem Tag="one">1</ComboBoxItem>
                        <ComboBoxItem Tag="one_hs">1 HS</ComboBoxItem>
                        <ComboBoxItem Tag="one_knife">1 K</ComboBoxItem>
                        <ComboBoxItem Tag="one_first">1 F</ComboBoxItem>
                        <ComboBoxItem Tag="one_last">1 L</ComboBoxItem>
                        <ComboBoxItem Tag="gold_first">GF</ComboBoxItem>
                        <ComboBoxItem Tag="gold_last">GL</ComboBoxItem>
                        <ComboBoxItem Tag="two">2</ComboBoxItem>
                        <ComboBoxItem Tag="three">3</ComboBoxItem>
                        <ComboBoxItem Tag="four">4</ComboBoxItem>
                        <ComboBoxItem Tag="five">5</ComboBoxItem>
                        <ComboBoxItem Tag="six">6</ComboBoxItem>
                        <ComboBoxItem Tag="seven">7</ComboBoxItem>
                        <ComboBoxItem Tag="eight">8</ComboBoxItem>
                        <ComboBoxItem Tag="nine">9</ComboBoxItem>
                        <ComboBoxItem Tag="badge_first">FK</ComboBoxItem>
                        <ComboBoxItem Tag="badge_last">LK</ComboBoxItem>
                    </ComboBox>

                    <Button
                        x:Name="SendTestButton"
                        Grid.Column="2"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        Click="OnTestEventClick"
