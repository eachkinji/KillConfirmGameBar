<UserControl
    x:Class="TestXboxGameBar.Controls.KillConfirmAnimation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    IsHitTestVisible="False"
    Visibility="Collapsed"
    mc:Ignorable="d">

    <Viewbox Stretch="Uniform">
        <Grid
            x:Name="Viewport"
            Width="400"
            Height="300">
            <Grid.Clip>
                <RectangleGeometry x:Name="ViewportClip" Rect="0,0,400,300" />
            </Grid.Clip>

            <canvas:CanvasControl
                x:Name="SpriteCanvas"
                Width="400"
                Height="300"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                ClearColor="Transparent"
                Draw="OnSpriteCanvasDraw" />

            <Border
                x:Name="LoadingOverlay"
                Width="150"
                Height="88"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#CC10131A"
                CornerRadius="6"
                Visibility="Collapsed">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
                    <ProgressRing
                        x:Name="LoadingRing"
                        Width="34"
                        Height="34"
                        IsActive="False" />
                    <TextBlock
                        x:Name="LoadingText"
                        HorizontalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Loading 0%" />
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>
