<Page
    x:Class="TestXboxGameBar.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TestXboxGameBar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0F171E">

    <Grid Padding="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel MaxWidth="720" HorizontalAlignment="Center">
            <TextBlock
                Text="Kill Confirm Overlay"
                FontFamily="Bahnschrift SemiBold"
                FontSize="32"
                FontWeight="SemiBold"
                Foreground="#F7FBFF" />
            <TextBlock
                Margin="0,8,0,0"
                Text="Xbox Game Bar widget"
                FontSize="16"
                Foreground="#B7C7D8"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <controls:KillConfirmAnimation
            x:Name="KillAnimation"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="8">
            <Button Content="1" Tag="1" Click="OnPreviewClick" />
            <Button Content="2" Tag="2" Click="OnPreviewClick" />
            <Button Content="3" Tag="3" Click="OnPreviewClick" />
            <Button Content="4" Tag="4" Click="OnPreviewClick" />
            <Button Content="5" Tag="5" Click="OnPreviewClick" />
        </StackPanel>
    </Grid>
</Page>
