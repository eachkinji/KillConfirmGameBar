<Page
    x:Class="TestXboxGameBar.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0F171E">

    <ScrollViewer>
        <Grid Padding="28" RowSpacing="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel MaxWidth="980" HorizontalAlignment="Center">
                <TextBlock
                    x:Name="TitleText"
                    Text="Kill Confirm Overlay"
                    FontFamily="Bahnschrift SemiBold"
                    FontSize="32"
                    FontWeight="SemiBold"
                    Foreground="#F7FBFF" />
                <TextBlock
                    x:Name="InstructionText"
                    Margin="0,8,0,0"
                    FontSize="16"
                    Foreground="#B7C7D8"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    x:Name="ShortcutText"
                    Margin="0,12,0,0"
                    FontSize="13"
                    Foreground="#8EA4B8"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Grid
                Grid.Row="1"
                MaxWidth="980"
                HorizontalAlignment="Center"
                ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.08*" />
                    <ColumnDefinition Width="0.92*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="12">
                    <Border
                        Padding="16"
                        Background="#16222D"
                        BorderBrush="#2B3D4C"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock
                                x:Name="VoiceCollectionsTitleText"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="#F7FBFF" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="VoiceCollectionsHintText"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#8EA4B8"
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    x:Name="ImportVoicePackButton"
                                    Grid.Column="1"
                                    Padding="12,6"
                                    Click="OnImportVoicePackClick"
                                    Content="导入语音包" />
                                <Button
                                    x:Name="CreateVoicePackButton"
                                    Grid.Column="2"
                                    Padding="12,6"
                                    Click="OnCreateVoicePackClick"
                                    Content="图形化新建" />
                            </Grid>
                            <TextBlock
                                x:Name="VoiceVisibleCountText"
                                FontSize="12"
                                Foreground="#BFD0E3" />
                            <StackPanel x:Name="VoicePackListPanel" Spacing="8" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="#16222D"
                        BorderBrush="#2B3D4C"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock
                                x:Name="IconCollectionsTitleText"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="#F7FBFF" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="IconCollectionsHintText"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#8EA4B8"
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    x:Name="ImportIconPackButton"
                                    Grid.Column="1"
                                    Padding="12,6"
                                    Click="OnImportIconPackClick"
                                    Content="导入图标包" />
                                <Button
                                    x:Name="CreateIconPackButton"
                                    Grid.Column="2"
                                    Padding="12,6"
                                    Click="OnCreateIconPackClick"
                                    Content="图形化新建" />
                            </Grid>
                            <TextBlock
                                x:Name="IconVisibleCountText"
                                FontSize="12"
                                Foreground="#BFD0E3" />
                            <StackPanel x:Name="IconPackListPanel" Spacing="8" />
                        </StackPanel>
                    </Border>

                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Spacing="12">
                    <Border
                        Padding="16"
                        Background="#101A23"
                        BorderBrush="#2B3D4C"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock
                                x:Name="StructureTitleText"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="#F7FBFF" />
                            <TextBlock
                                x:Name="StructureBodyText"
                                FontSize="13"
                                Foreground="#C8D6E4"
                                TextWrapping="WrapWholeWords" />
                            <Border
                                Padding="12"
                                Background="#172432"
                                BorderBrush="#375066"
                                BorderThickness="1"
                                CornerRadius="8">
                                <TextBlock
                                    x:Name="StructureListText"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Foreground="#D8E7F5"
                                    TextWrapping="WrapWholeWords" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
