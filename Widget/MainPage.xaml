<Page
    x:Class="TestXboxGameBar.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TestXboxGameBar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0F171E">

    <Grid Padding="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel MaxWidth="720" HorizontalAlignment="Center">
            <TextBlock
                Text="Kill Confirm Overlay"
                FontFamily="Bahnschrift SemiBold"
                FontSize="32"
                FontWeight="SemiBold"
                Foreground="#F7FBFF" />
            <TextBlock
                Margin="0,8,0,0"
                Text="Open Xbox Game Bar, then select Kill Confirm Overlay from the widget menu."
                FontSize="16"
                Foreground="#B7C7D8"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <controls:KillConfirmAnimation
            x:Name="KillAnimation"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            Spacing="10">
            <Button
                MinWidth="220"
                HorizontalAlignment="Center"
                Click="OnOpenGameBarClick"
                Content="Open Xbox Game Bar" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="13"
                Foreground="#7F96AA"
                Text="You can also press Win+G." />
        </StackPanel>
    </Grid>
</Page>
